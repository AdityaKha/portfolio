`Portfolio Contact from ${this.form.name}`);\n    const body = encodeURIComponent(\n      `Name: ${this.form.name}\\nEmail: ${this.form.email}\\n\\nMessage:\\n${this.form.message}`\n    );\n    window.location.href = `mailto:khandelwal.aditya5@gmail.com?subject=${subject}&body=${body}`;\n\n    setTimeout(() => {\n      this.sent.set(true);\n      this.loading.set(false);\n    }, 800);\n  }\n\n  resetForm() {\n    this.sent.set(false);\n    this.form = { name: '', email: '', message: '' };\n  }\n}\n"],"mappings":";AAAA,SAASA,SAAS,EAAEC,MAAM,QAAQ,eAAe;AACjD,SAASC,YAAY,QAAQ,iBAAiB;AAC9C,SAASC,WAAW,QAAQ,gBAAgB;AAE5C,MAAMC,OAAO,GAAG,CACd;EACEC,KAAK,EAAE,QAAQ;EACfC,MAAM,EAAE,YAAY;EACpBC,IAAI,EAAE,8BAA8B;EACpCC,IAAI,EAAE;CACP,EACD;EACEH,KAAK,EAAE,UAAU;EACjBC,MAAM,EAAE,YAAY;EACpBC,IAAI,EAAE,oCAAoC;EAC1CC,IAAI,EAAE;CACP,EACD;EACEH,KAAK,EAAE,UAAU;EACjBC,MAAM,EAAE,WAAW;EACnBC,IAAI,EAAE,kCAAkC;EACxCC,IAAI,EAAE;CACP,EACD;EACEH,KAAK,EAAE,OAAO;EACdC,MAAM,EAAE,8BAA8B;EACtCC,IAAI,EAAE,qCAAqC;EAC3CC,IAAI,EAAE;CACP,CACF;AA+KM,IAAMC,gBAAgB,GAAtB,MAAMA,gBAAgB;EAAtBC,YAAA;IACK,KAAAN,OAAO,GAAGA,OAAO;IAE3B,KAAAO,IAAI,GAAG;MACLC,IAAI,EAAE,EAAE;MACRC,KAAK,EAAE,EAAE;MACTC,OAAO,EAAE;KACV;IAED,KAAAC,IAAI,GAAGd,MAAM,CAAC,KAAK,CAAC;IACpB,KAAAe,OAAO,GAAGf,MAAM,CAAC,KAAK,CAAC;EAyBzB;EAvBEgB,YAAYA,CAAA;IACV,IAAI,CAAC,IAAI,CAACN,IAAI,CAACC,IAAI,IAAI,CAAC,IAAI,CAACD,IAAI,CAACE,KAAK,IAAI,CAAC,IAAI,CAACF,IAAI,CAACG,OAAO,EAAE;MAC7D;IACF;IAEA,IAAI,CAACE,OAAO,CAACE,GAAG,CAAC,IAAI,CAAC;IAEtB,MAAMC,OAAO,GAAGC,kBAAkB,CAAC,0BAA0B,IAAI,CAACT,IAAI,CAACC,IAAI,EAAE,CAAC;IAC9E,MAAMS,IAAI,GAAGD,kBAAkB,CAC7B,SAAS,IAAI,CAACT,IAAI,CAACC,IAAI,YAAY,IAAI,CAACD,IAAI,CAACE,KAAK,iBAAiB,IAAI,CAACF,IAAI,CAACG,OAAO,EAAE,CACvF;IACDQ,MAAM,CAACC,QAAQ,CAAChB,IAAI,GAAG,+CAA+CY,OAAO,SAASE,IAAI,EAAE;IAE5FG,UAAU,CAAC,MAAK;MACd,IAAI,CAACT,IAAI,CAACG,GAAG,CAAC,IAAI,CAAC;MACnB,IAAI,CAACF,OAAO,CAACE,GAAG,CAAC,KAAK,CAAC;IACzB,CAAC,EAAE,GAAG,CAAC;EACT;EAEAO,SAASA,CAAA;IACP,IAAI,CAACV,IAAI,CAACG,GAAG,CAAC,KAAK,CAAC;IACpB,IAAI,CAACP,IAAI,GAAG;